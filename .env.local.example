# Copy to .env.local and fill in real values. NEVER commit .env.local.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─── Resend (transactional email) ────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=
ADMIN_EMAIL=

# ─── OpenAI (Pheidi chat) ────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Stripe (Pheidi Pro paywall) ─────────────────────────────────────────────
# Local: use sk_test_… and a test-mode price ID.
# Vercel production: MUST use sk_live_…, the live-mode webhook signing secret,
# and the live-mode price ID. Production webhooks point to:
#   https://www.finishultra.com/api/stripe/webhook
# Subscribed events: checkout.session.completed, customer.subscription.created,
# customer.subscription.deleted.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_ID=
